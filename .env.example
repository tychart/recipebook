# Database
PG_USER=RecipeAdmin
PG_PASSWORD=RecipeBookPasswordChangeMe # This should be changed to be unique


# S3 / RustFS
# S3_ENDPOINT is the internal/raw S3 API endpoint the backend talks to.
# S3_PUBLIC_ENDPOINT is the public base URL used when rewriting image URLs.
S3_ENDPOINT=http://recipebook-rustfs:9000
S3_PUBLIC_ENDPOINT=http://localhost:8650/s3
S3_BUCKET=recipe-images
S3_KEY=rustfsadmin
S3_SECRET=rustfsadmin

# ML Config
OLLAMA_BASE_URL=http://recipebook-ollama:11434/v1
OPENAI_API_KEY=ollama   # Set this to be your OpenAI api key if using OpenAI model
OLLAMA_PORT=11434
ML_BASE_URL=http://recipebook-ml:8001
ML_TIMEOUT_SECONDS=120
ML_PORT=8001
ML_OCR_ENGINE=paddleocr
ML_OCR_AUTO_FALLBACK=true
ML_OCR_TESSERACT_LANG=eng
ML_OCR_PADDLE_DEVICE=cpu
ML_OCR_PADDLE_MODEL=PaddleOCR-VL-1.5
ML_PADDLE_PACKAGE=paddlepaddle==3.2.0
ML_PADDLE_INDEX_URL=https://www.paddlepaddle.org.cn/packages/stable/cpu/
LLM_MODEL=lfm2.5-thinking # Nice and small starter model
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_VECTOR_SIZE=768
LOG_LEVEL=INFO
