# Database
DATABASE_URL=postgresql://recipebook:recipebook@recipebook-db:5432/recipebook

# Storage mode: "proxy" (default) or "presign"
STORAGE_MODE=proxy

# S3 / rustfs settings (only used when STORAGE_MODE=presign)
S3_ENDPOINT=http://recipebook-rustfs:9000
S3_PUBLIC_BASE=https://storage.example.com         # optional public host for presigned URLs
S3_BUCKET=recipe-images
S3_KEY=rustfsadmin
S3_SECRET=rustfsadmin
S3_REGION=us-east-1

# Optionally allow exposing rustfs locally for debugging (true/false)
EXPOSE_RUSTFS=false