# Database
PG_USER=RecipeAdmin
PG_PASSWORD=RecipeBookPasswordChangeMe # This should be changed to be unique


# S3 / RustFS
# S3_ENDPOINT is the internal/raw S3 API endpoint the backend talks to.
# S3_PUBLIC_ENDPOINT is the public base URL used when rewriting image URLs.
S3_ENDPOINT=http://recipebook-rustfs:9000
S3_PUBLIC_ENDPOINT=http://localhost:8650/s3
S3_BUCKET=recipe-images
S3_KEY=rustfsadmin
S3_SECRET=rustfsadmin

# LLM Config
LLM_BASE_URL=http://recipebook-ollama:11434/v1
LLM_API_KEY=ollama   # Set this to your real API key when not using Ollama
OLLAMA_PORT=11434
LLM_MODEL=qwen3-vl:2b # Nice and small vision capable model
LLM_REQUEST_TIMEOUT=300
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_VECTOR_SIZE=768
LOG_LEVEL=INFO
